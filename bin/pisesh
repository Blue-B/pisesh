#!/usr/bin/env node
// pisesh — pi session bookmark & resume TUI
// Tabs: ★ Favorites / Today / Here / All
// Storage: ~/.pi/agent/favorites.json   (starred session ids)
//          ~/.pi/agent/pisesh-meta.json (per-session title / cwd overrides)
// Sessions: ~/.pi/agent/sessions/<projectSlug>/<ts>_<uuid>.jsonl

'use strict';

const fs = require('fs');
const path = require('path');
const os = require('os');
const { spawn } = require('child_process');
const readline = require('readline');

// ── Paths ─────────────────────────────────────────────
const HOME = os.homedir();
const SESSIONS_ROOT = path.join(HOME, '.pi/agent/sessions');
const FAV_FILE = path.join(HOME, '.pi/agent/favorites.json');
const META_FILE = path.join(HOME, '.pi/agent/pisesh-meta.json');

// Current session id (set by the /sesh extension before spawning). Lets us
// flag the currently-attached session in the list with a [NOW] badge.
const CURRENT_SESSION_ID = (process.env.PISESH_CURRENT_SESSION || '').trim();

// Directory pisesh was launched from. The /sesh extension forwards pi's cwd
// via PISESH_CWD; falling back to process.cwd() keeps standalone use working.
// Drives the "Here" tab (sessions whose effective cwd matches this dir).
const CURRENT_CWD = (process.env.PISESH_CWD || process.cwd() || '').replace(/\/+$/, '');
// When launched through /sesh, the extension forwards pi's active model. The
// standalone CLI falls back to pi's configured default from settings.json.
const CURRENT_PI_MODEL = (process.env.PISESH_PI_MODEL || '').trim();
const PI_SETTINGS_FILE = path.join(HOME, '.pi/agent/settings.json');

// ── ANSI ──────────────────────────────────────────────
const A = {
  clr: '\x1b[2J\x1b[H',
  // Alternate screen buffer: draws into a separate buffer so tab-switching
  // never pushes prior renders into terminal scrollback. On exit the user's
  // pre-pisesh terminal content is restored byte-for-byte. Same trick as
  // less/vim/htop/droid-cli.
  enterAlt: '\x1b[?1049h',
  exitAlt: '\x1b[?1049l',
  hideC: '\x1b[?25l',
  showC: '\x1b[?25h',
  R: '\x1b[0m',
  B: '\x1b[1m',
  D: '\x1b[2m',
  I: '\x1b[7m',
  yel: '\x1b[33m',
  cyn: '\x1b[36m',
  grn: '\x1b[32m',
  mag: '\x1b[35m',
  red: '\x1b[31m',
  gry: '\x1b[90m',
  bgBlu: '\x1b[44m',
};

// ── Persistence ───────────────────────────────────────
function loadFavorites() {
  try {
    const raw = fs.readFileSync(FAV_FILE, 'utf8');
    const data = JSON.parse(raw);
    return new Set(data.ids || []);
  } catch { return new Set(); }
}

function saveFavorites(set) {
  const data = { ids: [...set], updated: new Date().toISOString() };
  try {
    fs.mkdirSync(path.dirname(FAV_FILE), { recursive: true });
    fs.writeFileSync(FAV_FILE, JSON.stringify(data, null, 2));
  } catch (e) {
    console.error('save favorites failed:', e.message);
  }
}

let favorites = loadFavorites();

// ── Per-session overrides (title / cwd) ───────────────────
// Session jsonl files are treated as read-only history, so user edits to a
// session's display title or resume cwd live in a sidecar file keyed by id:
//   { overrides: { "<id>": { title?: string, cwd?: string } }, updated }
function loadMeta() {
  try {
    const data = JSON.parse(fs.readFileSync(META_FILE, 'utf8'));
    return {
      overrides: (data && typeof data.overrides === 'object' && data.overrides) || {},
      settings: (data && typeof data.settings === 'object' && data.settings) || {},
    };
  } catch { return { overrides: {}, settings: {} }; }
}

function saveMeta() {
  const data = { settings: metaSettings, overrides: meta, updated: new Date().toISOString() };
  try {
    fs.mkdirSync(path.dirname(META_FILE), { recursive: true });
    fs.writeFileSync(META_FILE, JSON.stringify(data, null, 2));
  } catch (e) {
    console.error('save meta failed:', e.message);
  }
}

const loadedMeta = loadMeta();
let meta = loadedMeta.overrides;
let metaSettings = loadedMeta.settings;

// Override record for one session id (always returns an object, never null).
// Used by the per-session getters, which can't read the global `meta`
// directly because scanSessions() shadows it with a local variable.
function overridesFor(id) { return meta[id] || {}; }

// Set (or clear, when value is empty) one override field for a session, then
// persist. Empty string deletes the field so the row falls back to defaults;
// an emptied override object is dropped entirely to keep the file tidy.
function setOverride(id, field, value) {
  if (!id) return;
  const v = (value || '').trim();
  const entry = meta[id] || {};
  if (v) entry[field] = v;
  else delete entry[field];
  if (Object.keys(entry).length) meta[id] = entry;
  else delete meta[id];
  saveMeta();
}

function saveTitle(id, value, source, model, thinkingLevel) {
  if (!id) return;
  const v = (value || '').trim();
  const entry = meta[id] || {};
  if (v) {
    entry.title = v;
    entry.titleSource = source;
    if (source === 'llm' && model) {
      entry.titleModel = model;
      entry.titleThinkingLevel = thinkingLevel || 'off';
    } else {
      delete entry.titleModel;
      delete entry.titleThinkingLevel;
    }
  } else {
    delete entry.title;
    delete entry.titleSource;
    delete entry.titleModel;
    delete entry.titleThinkingLevel;
  }
  if (Object.keys(entry).length) meta[id] = entry;
  else delete meta[id];
  saveMeta();
}

// ── Project slug decode ───────────────────────────────
// pi encodes cwd by replacing '/' with '-' and wrapping in '--…--'
// "--mnt-c-Users-root--"                       → "/mnt/c/Users/root"
// "--mnt-c-Users-root-Downloads-instareal--"   → "/mnt/c/Users/root/Downloads/instareal"
// "--home-shell--"                             → "/home/shell"
function decodeProjectSlug(slug) {
  let s = slug;
  if (s.startsWith('--')) s = '/' + s.slice(2);
  if (s.endsWith('--')) s = s.slice(0, -2);
  return s.replace(/-/g, '/');
}

function shortCwd(cwd, max = 18) {
  const parts = cwd.split('/').filter(Boolean);
  if (parts.length === 0) return cwd;
  const last = parts[parts.length - 1];
  // Use display-cell truncation so CJK project names don't blow up the column.
  return trunc(last, max);
}

// ── Scan sessions ─────────────────────────────────────
function readSessionMeta(file) {
  // Read up to 96 KB to find session line + first user prompt
  let buf;
  try {
    const fd = fs.openSync(file, 'r');
    const tmp = Buffer.alloc(96 * 1024);
    const n = fs.readSync(fd, tmp, 0, tmp.length, 0);
    fs.closeSync(fd);
    buf = tmp.slice(0, n).toString('utf8');
  } catch { return null; }

  const lines = buf.split('\n');
  let session = null;
  let firstPrompt = '';
  for (const line of lines) {
    if (!line.trim()) continue;
    let obj;
    try { obj = JSON.parse(line); }
    catch { continue; } // truncated last line is fine

    if (!session && obj.type === 'session') session = obj;

    if (!firstPrompt && obj.type === 'message' && obj.message && obj.message.role === 'user') {
      const content = obj.message.content;
      let text = '';
      if (Array.isArray(content)) {
        for (const c of content) {
          if (c && c.type === 'text' && c.text) { text = c.text; break; }
        }
      } else if (typeof content === 'string') text = content;
      if (text.trim()) firstPrompt = text.trim();
    }

    if (session && firstPrompt) break;
  }
  if (!session) return null;
  session.firstPrompt = firstPrompt;
  return session;
}

function scanSessions() {
  let projectDirs;
  try {
    projectDirs = fs.readdirSync(SESSIONS_ROOT, { withFileTypes: true })
      .filter(d => d.isDirectory());
  } catch { return []; }

  const results = [];
  for (const d of projectDirs) {
    const projectPath = path.join(SESSIONS_ROOT, d.name);
    const projectLabel = decodeProjectSlug(d.name);
    let files;
    try { files = fs.readdirSync(projectPath).filter(f => f.endsWith('.jsonl')); }
    catch { continue; }

    for (const f of files) {
      const full = path.join(projectPath, f);
      let st;
      try { st = fs.statSync(full); } catch { continue; }
      const meta = readSessionMeta(full);
      if (!meta || !meta.id) continue;
      results.push({
        id: meta.id,
        ts: meta.timestamp,
        mtime: st.mtime,
        cwd: meta.cwd || projectLabel,
        project: projectLabel,
        projectSlug: d.name,
        file: full,
        prompt: meta.firstPrompt || '',
        size: st.size,
        get favored() { return favorites.has(this.id); },
        get isCurrent() { return CURRENT_SESSION_ID !== '' && this.id === CURRENT_SESSION_ID; },
        // User overrides (sidecar meta). cwd: from is the original recorded cwd.
        get titleOverride() { return (overridesFor(this.id).title || '').trim(); },
        get titleSource() { return overridesFor(this.id).titleSource || (this.titleOverride ? 'manual' : ''); },
        get titleModel() { return overridesFor(this.id).titleModel || ''; },
        get titleThinkingLevel() { return overridesFor(this.id).titleThinkingLevel || ''; },
        get cwdOverride() { return (overridesFor(this.id).cwd || '').trim(); },
        // Name shown in the list: custom title > first prompt > id fallback.
        get title() {
          return this.titleOverride || this.prompt || `(no prompt) ${this.id.slice(0, 8)}`;
        },
        // cwd actually used to resume / filter by "Here": override wins.
        get effectiveCwd() { return this.cwdOverride || this.cwd; },
      });
    }
  }
  results.sort((a, b) => b.mtime - a.mtime);
  return results;
}

// ── State ─────────────────────────────────────────────
let sessions = [];
let tabs = ['★ Favorites', 'Today', 'Here', 'All'];
let tabIdx = 0;
let cursor = 0;
let filter = '';
let mode = 'list';      // list | filter | details | edit | browse | model
// edit mode state (title text editor)
let editField = '';     // 'title' | 'cwd'
let editBuffer = '';
let editCursor = 0;     // caret position (code-point index into editBuffer)
let editTarget = null;  // the session being edited
// browse mode state (arrow-key cwd directory picker)
let browseDir = '';        // directory currently being browsed (absolute)
let browseEntries = [];    // [{ label, kind:'use'|'up'|'dir', path }]
let browseSel = 0;         // selected row in browseEntries
// LLM title generation state
let models = [];
let modelSel = 0;
let modelFilter = '';
let modelStatus = '';
let modelThinking = new Set();
let modelEffort = 'off';
const EFFORT_LEVELS = ['off', 'minimal', 'low', 'medium', 'high', 'xhigh', 'max'];
const TITLE_GENERATION_CONCURRENCY = 3;
let generationChildren = new Map(); // target id -> ChildProcess
let generationCancelled = false;
let settingsPendingTarget = null;
let generationJobs = []; // queued [{ target, model, effort }]
let generationActive = false;
let handingOff = false;

function configuredPiModel() {
  if (CURRENT_PI_MODEL) return CURRENT_PI_MODEL;
  try {
    const settings = JSON.parse(fs.readFileSync(PI_SETTINGS_FILE, 'utf8'));
    if (settings.defaultProvider && settings.defaultModel) {
      return `${settings.defaultProvider}/${settings.defaultModel}`;
    }
  } catch {}
  return '';
}

function parseModelEntries(output) {
  return output.split(/\r?\n/).slice(1).map(line => {
    const cols = line.trim().split(/\s+/);
    return cols.length >= 6 ? { id: `${cols[0]}/${cols[1]}`, thinking: cols[4] === 'yes' } : null;
  }).filter(Boolean);
}

function parseModelList(output) {
  return parseModelEntries(output).map(entry => entry.id);
}

function textFromContent(content) {
  if (typeof content === 'string') return content.trim();
  if (!Array.isArray(content)) return '';
  return content.filter(x => x && x.type === 'text' && x.text).map(x => x.text.trim()).filter(Boolean).join('\n');
}

const TITLE_PROMPT = `Generate a durable, factual topic label for this coding session.
Describe what the session is about, not what the assistant completed or reported.
Do not summarize or quote the conversation.

Output exactly one line:
<3-8 word title>: <6-14 word subtitle>

Title requirements (highest priority):
- The title must stand alone because the subtitle may be truncated in the session list
- Use a base-form action such as Review, Rebase, Refactor, Resolve, Fix, Add, Remove, or Investigate
- Put the core subject, action, exact target, and distinguishing scope in the title
- Name human-readable identifiers whenever available: PR number or name, branch, class, function, filename, package, command, or issue
- Describe the central task or topic independent of its progress or completion state
- Never encode status or bookkeeping such as completed, done, finished, committed, updated, tests passed, or test counts
- Use factual, impersonal wording; never use I, we, you, I'll, I will, let's, or going to
- Never describe the assistant's plan, promise, tool usage, response, next step, or accomplishments
- Never copy a sentence from the conversation
- Omit commit hashes; unlike PR numbers, they are not useful human-readable identifiers
- When referring to a path, prefer the filename alone; include directories only when needed to disambiguate
- Count every slash-separated path component as one word toward the 3-8 word limit (for example, src/auth/Login.ts counts as three words)
- Prefer specific technical nouns over generic descriptions

Subtitle requirements:
- Use 6-14 words in one concise, factual imperative sentence
- Begin with a base-form action verb such as Add, Apply, Check, Extract, Implement, Inspect, Preserve, or Remove
- Use parallel imperative verb phrases when naming multiple actions
- Describe technical scope, constraints, or subject matter not already in the title
- Avoid report-style verbs such as covers, adds, identifies, resolves, or completed
- Do not report progress, completion, commit history, todo updates, or test counts unless testing is the session's central topic
- Use assistant evidence only to clarify the topic, target, and scope; ignore its status and process wording
- Do not repeat or rephrase the title

Examples:
Resolve sample-service Audit Findings: Apply focused refactors, tighten authorization, and bound cache growth.
Review desktop-client Concurrency Changes: Check lifecycle, thread safety, and event ownership.
Review PR #42 Token Refresh: Inspect refresh concurrency and add regression coverage.
Rebase feature/auth onto main: Resolve middleware conflicts and preserve session handling compatibility.
Refactor SessionManager Retry Logic: Extract backoff policy and remove duplicated state transitions.

General requirements:
- Use exactly one colon to separate the title and subtitle
- No quotation marks
- Output only the title and subtitle`;

function boundTitleContext(text, maxChars) {
  if (text.length <= maxChars) return text;
  const marker = '\n\n[earlier context omitted]\n\n';
  if (maxChars <= marker.length) return text.slice(0, maxChars);
  const available = maxChars - marker.length;
  const head = Math.floor(available * 0.4);
  return text.slice(0, head) + marker + text.slice(-(available - head));
}

function buildTitlePrompt(file, maxChars = 16000) {
  const userRequests = [];
  const assistantReports = [];
  let sessionCwd = '';
  try {
    for (const line of fs.readFileSync(file, 'utf8').split('\n')) {
      if (!line.trim()) continue;
      let obj;
      try { obj = JSON.parse(line); } catch { continue; }
      if (obj.type === 'session' && !sessionCwd && typeof obj.cwd === 'string') {
        sessionCwd = obj.cwd.trim();
        continue;
      }
      if (obj.type !== 'message' || !obj.message) continue;
      const { role, content, stopReason } = obj.message;
      if (role !== 'user' && role !== 'assistant') continue;
      const text = textFromContent(content);
      if (!text) continue;
      if (role === 'user') {
        userRequests.push(`User request ${userRequests.length + 1}: ${text}`);
        continue;
      }
      const hasToolCall = Array.isArray(content) && content.some(x => x && x.type === 'toolCall');
      if (!hasToolCall && stopReason !== 'error' && stopReason !== 'aborted') {
        assistantReports.push(`Assistant evidence ${assistantReports.length + 1}: ${text}`);
      }
    }
  } catch (e) { throw new Error(`could not read session: ${e.message}`); }
  if (!userRequests.length && !assistantReports.length) throw new Error('no conversation text found');

  const userText = userRequests.join('\n\n');
  const assistantText = assistantReports.join('\n\n');
  const totalBudget = Math.max(0, maxChars);
  let userBudget = Math.min(userText.length, Math.floor(totalBudget * 0.7));
  let assistantBudget = Math.min(assistantText.length, totalBudget - userBudget);
  let remaining = totalBudget - userBudget - assistantBudget;
  const extraUser = Math.min(remaining, userText.length - userBudget);
  userBudget += extraUser;
  remaining -= extraUser;
  assistantBudget += Math.min(remaining, assistantText.length - assistantBudget);

  const sections = [];
  const cwdParts = sessionCwd.replace(/[\\/]+$/, '').split(/[\\/]/).filter(Boolean);
  if (cwdParts.length) sections.push(`Session context:\nWorking directory: ${cwdParts[cwdParts.length - 1]}`);
  if (userText) sections.push(`User requests (authoritative task context):\n${boundTitleContext(userText, userBudget)}`);
  if (assistantText) sections.push(`Assistant evidence (use only for topic, target, and scope; ignore completion and process wording):\n${boundTitleContext(assistantText, assistantBudget)}`);
  return `${TITLE_PROMPT}\n\nConversation evidence:\n${sections.join('\n\n')}`;
}

function cleanGeneratedTitle(output) {
  let title = (output || '').split(/\r?\n/).map(x => x.trim()).find(Boolean) || '';
  title = title.replace(/^title\s*:\s*/i, '').replace(/^["'“”‘’`]+|["'“”‘’`]+$/g, '').replace(/\s+/g, ' ').trim();
  if (!title) throw new Error('model returned an empty title');
  return [...title].slice(0, 200).join('');
}

// ── Filtering by tab ──────────────────────────────────
function visibleSessions() {
  let list = sessions;
  const tab = tabs[tabIdx];

  if (tab.startsWith('★')) {
    list = list.filter(s => s.favored);
  } else if (tab === 'Today') {
    const today = new Date().toLocaleDateString('sv-SE'); // YYYY-MM-DD
    list = list.filter(s => new Date(s.mtime).toLocaleDateString('sv-SE') === today);
  } else if (tab === 'Here') {
    // Only sessions whose effective cwd is the directory pisesh was launched
    // from (trailing slashes normalized so /foo and /foo/ match).
    const here = CURRENT_CWD.replace(/\/+$/, '');
    list = list.filter(s => (s.effectiveCwd || '').replace(/\/+$/, '') === here);
  }

  if (filter) {
    const q = filter.toLowerCase();
    list = list.filter(s =>
      s.id.toLowerCase().includes(q) ||
      s.project.toLowerCase().includes(q) ||
      s.prompt.toLowerCase().includes(q) ||
      s.title.toLowerCase().includes(q)
    );
  }
  return list;
}

// ── Format helpers ────────────────────────────────────
function fmtTs(d) {
  const x = new Date(d);
  const m = String(x.getMonth() + 1).padStart(2, '0');
  const day = String(x.getDate()).padStart(2, '0');
  const hh = String(x.getHours()).padStart(2, '0');
  const mm = String(x.getMinutes()).padStart(2, '0');
  return `${m}/${day} ${hh}:${mm}`;
}

function fmtSize(n) {
  if (n < 1024) return n + 'B';
  if (n < 1024 * 1024) return (n / 1024).toFixed(0) + 'K';
  return (n / 1024 / 1024).toFixed(1) + 'M';
}

// Returns the visible cell width of a character. CJK ideographs,
// Hangul syllables, fullwidth forms, and most emoji render 2 cells wide
// in modern terminals; everything else is 1. Without this every row that
// contains Korean/Chinese/Japanese text would silently wrap, breaking the
// fixed-column TUI layout. Based on the East Asian Width property
// (UAX #11) compressed to the ranges that actually appear in practice.
function charWidth(cp) {
  if (cp < 0x1100) return 1;
  if (
    (cp >= 0x1100 && cp <= 0x115f) ||                 // Hangul Jamo
    cp === 0x2329 || cp === 0x232a ||
    (cp >= 0x2e80 && cp <= 0x303e) ||                 // CJK Radicals/Kangxi
    (cp >= 0x3041 && cp <= 0x33ff) ||                 // Hiragana/Katakana/CJK Symbols
    (cp >= 0x3400 && cp <= 0x4dbf) ||                 // CJK Ext A
    (cp >= 0x4e00 && cp <= 0x9fff) ||                 // CJK Unified
    (cp >= 0xa000 && cp <= 0xa4cf) ||                 // Yi
    (cp >= 0xac00 && cp <= 0xd7a3) ||                 // Hangul Syllables
    (cp >= 0xf900 && cp <= 0xfaff) ||                 // CJK Compat
    (cp >= 0xfe30 && cp <= 0xfe4f) ||                 // CJK Compat Forms
    (cp >= 0xff00 && cp <= 0xff60) ||                 // Fullwidth ASCII
    (cp >= 0xffe0 && cp <= 0xffe6) ||                 // Fullwidth signs
    (cp >= 0x1f300 && cp <= 0x1f64f) ||               // Emoji symbols
    (cp >= 0x1f680 && cp <= 0x1f6ff) ||               // Transport/map
    (cp >= 0x1f900 && cp <= 0x1f9ff) ||               // Supplemental symbols
    (cp >= 0x20000 && cp <= 0x2fffd)                  // CJK Ext B-F
  ) return 2;
  return 1;
}

function displayWidth(s) {
  if (!s) return 0;
  let w = 0;
  for (const ch of s) w += charWidth(ch.codePointAt(0));
  return w;
}

// Pad `s` to exactly `n` display cells. If wider, truncate; if narrower,
// right-pad with spaces. Operates on cells, not code units.
function pad(s, n) {
  if (!s) s = '';
  const w = displayWidth(s);
  if (w === n) return s;
  if (w < n) return s + ' '.repeat(n - w);
  // Wider than n — truncate character-by-character.
  let out = '', cur = 0;
  for (const ch of s) {
    const cw = charWidth(ch.codePointAt(0));
    if (cur + cw > n) break;
    out += ch; cur += cw;
  }
  if (cur < n) out += ' '.repeat(n - cur);
  return out;
}

// Truncate `s` so that displayWidth(out) ≤ maxWidth, appending '…' when
// truncated. Whitespace runs (including newlines) collapse to one space.
function trunc(s, maxWidth) {
  if (!s) return '';
  s = s.replace(/\s+/g, ' ').trim();
  if (displayWidth(s) <= maxWidth) return s;
  let out = '', cur = 0;
  for (const ch of s) {
    const cw = charWidth(ch.codePointAt(0));
    if (cur + cw > maxWidth - 1) break;     // reserve 1 cell for the …
    out += ch; cur += cw;
  }
  return out + '…';
}

function visLen(s) {
  // strip ANSI escapes, then measure in display cells
  return displayWidth(s.replace(/\x1b\[[0-9;]*m/g, ''));
}

// ── Render ────────────────────────────────────────────
function render() {
  if (mode === 'edit') return renderEdit();
  if (mode === 'browse') return renderBrowse();
  if (mode === 'model') return renderModelPicker();
  if (mode === 'details') return renderDetails();
  renderList();
}

function renderList() {
  const W = process.stdout.columns || 100;
  const H = process.stdout.rows || 30;
  let out = A.clr;

  // Header
  out += ' ' + A.B + A.cyn + 'pisesh' + A.R + A.D + '  pi session bookmarks  ' + A.R;
  out += A.gry + `${sessions.length} sessions · ${favorites.size} starred` + A.R;
  out += '\n\n';

  // Tabs
  let tabLine = ' ';
  tabs.forEach((t, i) => {
    if (i === tabIdx) tabLine += A.I + A.B + ' ' + t + ' ' + A.R + '  ';
    else tabLine += A.D + ' ' + t + ' ' + A.R + '  ';
  });
  out += tabLine + '\n';
  out += A.gry + '─'.repeat(Math.max(1, W - 1)) + A.R + '\n';

  // Filter line
  if (mode === 'filter' || filter) {
    const caret = mode === 'filter' ? A.I + ' ' + A.R : '';
    out += ' ' + A.cyn + '/' + A.R + ' ' + filter + caret + '\n';
    out += A.gry + '─'.repeat(Math.max(1, W - 1)) + A.R + '\n';
  }

  // List
  const list = visibleSessions();
  if (cursor >= list.length) cursor = Math.max(0, list.length - 1);

  const headerH = (mode === 'filter' || filter) ? 7 : 5;
  const footerH = 4;
  const usable = Math.max(3, H - headerH - footerH);
  const start = Math.max(0, Math.min(cursor - Math.floor(usable / 2), list.length - usable));
  const end = Math.min(list.length, start + usable);

  if (list.length === 0) {
    let hint;
    if (filter) {
      hint = '(no matches — Esc clears filter)';
    } else if (tabs[tabIdx].startsWith('★')) {
      hint = '(no favorites yet — press f on any session to star it)';
    } else if (tabs[tabIdx] === 'Today') {
      hint = '(no sessions today — Tab to see All)';
    } else if (tabs[tabIdx] === 'Here') {
      hint = `(no sessions in ${CURRENT_CWD || 'this dir'} — Tab to see All)`;
    } else {
      hint = '(no sessions in this view)';
    }
    out += '\n ' + A.D + hint + A.R + '\n';
  } else {
    for (let i = start; i < end; i++) {
      const s = list[i];
      const sel = i === cursor;
      const star = s.favored ? A.yel + '★' + A.R : ' ';
      const arrow = sel ? A.cyn + '▶' + A.R : ' ';
      const currentJob = generationActive && generationChildren.has(s.id);
      const queuedJob = generationActive && generationJobs.some(job => job.target.id === s.id);
      const ts = A.gry + fmtTs(s.mtime) + A.R;
      const cwd = A.mag + pad(shortCwd(s.effectiveCwd), 14) + A.R;
      const badge = s.isCurrent ? A.grn + A.B + '[NOW]' + A.R + ' ' : '';
      // Generation state and title provenance share one stable marker column.
      const marker = currentJob
        ? A.yel + '↻' + A.R + ' '
        : queuedJob
          ? A.gry + '·' + A.R + ' '
          : s.titleOverride
            ? A.cyn + (s.titleSource === 'llm' ? '◆' : '✎') + A.R + ' '
            : '';
      const titleMax = Math.max(20, W - 38 - (s.isCurrent ? 7 : 0) - (marker ? 2 : 0));
      const title = trunc(s.title, titleMax);
      const rowText = ` ${arrow} ${star} ${ts}  ${cwd}  ${badge}${marker}${title}`;
      if (sel) {
        const pad2 = ' '.repeat(Math.max(0, W - visLen(rowText) - 1));
        out += A.bgBlu + rowText + pad2 + A.R + '\n';
      } else {
        out += rowText + '\n';
      }
    }
  }

  // Pad bottom to push footer down
  const linesUsed = (end - start) || 1;
  for (let i = 0; i < usable - linesUsed; i++) out += '\n';

  // Footer
  out += A.gry + '─'.repeat(Math.max(1, W - 1)) + A.R + '\n';
  out += ' ' + A.D + '↑↓' + A.R + ' move  '
      + A.D + 'Tab' + A.R + ' tab  '
      + A.D + 'f' + A.R + ' star  '
      + A.D + 'Enter' + A.R + ' resume  '
      + A.D + 'e' + A.R + ' edit name  '
      + A.D + 'g' + A.R + ' queue title  '
      + A.D + 'G' + A.R + ' settings  '
      + A.D + 'p' + A.R + ' edit cwd  '
      + A.D + 'd' + A.R + ' details  '
      + A.D + '/' + A.R + ' search  '
      + A.D + 'q' + A.R + ' quit' + A.R + '\n';

  process.stdout.write(out);
}

function filteredModels() {
  const q = modelFilter.toLowerCase();
  return q ? models.filter(m => m.toLowerCase().includes(q)) : models;
}

function renderModelPicker() {
  const W = process.stdout.columns || 100;
  const H = process.stdout.rows || 30;
  const list = filteredModels();
  if (modelSel >= list.length) modelSel = Math.max(0, list.length - 1);
  let out = A.clr;
  out += ' ' + A.B + A.cyn + 'pisesh' + A.R + A.D + '  title generation settings' + A.R + '\n\n';
  if (settingsPendingTarget) out += ' ' + A.D + 'generate' + A.R + '  ' + trunc(settingsPendingTarget.title, W - 14) + '\n';
  out += ' ' + A.D + 'filter ' + A.R + A.cyn + modelFilter + A.R + (modelFilter ? A.I + ' ' + A.R : '') + '\n';
  out += A.gry + '─'.repeat(Math.max(1, W - 1)) + A.R + '\n';
  if (modelStatus) out += '\n ' + A.D + modelStatus + A.R + '\n';
  else if (!list.length) out += '\n ' + A.D + '(no matching models)' + A.R + '\n';
  else {
    const effortWidths = EFFORT_LEVELS.map(level => level.length + 2);
    const effortTotal = effortWidths.reduce((sum, width) => sum + width, 0);
    const modelWidth = Math.max(12, W - effortTotal - 5);
    out += '   ' + A.D + pad('model', modelWidth) + pad('effort', effortTotal) + A.R + '\n';
    const usable = Math.max(3, H - 10);
    const start = Math.max(0, Math.min(modelSel - Math.floor(usable / 2), list.length - usable));
    for (let i = start; i < Math.min(list.length, start + usable); i++) {
      const selected = i === modelSel;
      const supportsEffort = modelThinking.has(list[i]);
      let row = ' ' + (selected ? A.cyn + '▶' + A.R : ' ') + ' ';
      row += (selected ? A.B : '') + pad(trunc(list[i], modelWidth), modelWidth) + (selected ? A.R : '');
      for (let j = 0; j < EFFORT_LEVELS.length; j++) {
        const level = EFFORT_LEVELS[j];
        const available = supportsEffort || level === 'off';
        const cell = pad(available ? level : '—', effortWidths[j]);
        if (selected && level === modelEffort) row += A.bgBlu + A.B + cell + A.R;
        else row += available ? A.D + cell + A.R : A.gry + cell + A.R;
      }
      out += row + '\n';
    }
  }
  out += '\n' + A.gry + '─'.repeat(Math.max(1, W - 1)) + A.R + '\n';
  out += ' ' + A.D + '↑↓' + A.R + ' model  ' + A.D + '←→' + A.R + ' effort  '
      + A.D + 'type' + A.R + ' filter  ' + A.grn + A.B + 'Enter' + A.R + ' save  '
      + A.D + 'Esc' + A.R + ' cancel\n';
  process.stdout.write(out);
}

function openGenerationSettings(pendingTarget = null) {
  settingsPendingTarget = pendingTarget;
  modelFilter = '';
  modelSel = 0;
  mode = 'model';
  modelStatus = 'Loading models from pi…';
  render();
  let stdout = '', stderr = '';
  const child = spawn('pi', ['--list-models'], { stdio: ['ignore', 'pipe', 'pipe'] });
  child.stdout.on('data', d => { stdout += d; });
  child.stderr.on('data', d => { stderr += d; });
  child.on('error', e => { if (mode === 'model') { modelStatus = `Could not run pi: ${e.message}`; render(); } });
  child.on('close', code => {
    if (mode !== 'model') return;
    const entries = code === 0 ? parseModelEntries(stdout) : [];
    models = entries.map(entry => entry.id);
    modelThinking = new Set(entries.filter(entry => entry.thinking).map(entry => entry.id));
    modelStatus = models.length ? '' : `Could not list models${stderr.trim() ? `: ${stderr.trim()}` : ''}`;
    const preferred = [metaSettings.titleModel, configuredPiModel()].filter(Boolean);
    const idx = preferred.map(m => models.indexOf(m)).find(i => i >= 0);
    modelSel = idx !== undefined ? idx : 0;
    modelEffort = EFFORT_LEVELS.includes(metaSettings.titleThinkingLevel) ? metaSettings.titleThinkingLevel : 'off';
    if (!modelThinking.has(models[modelSel])) modelEffort = 'off';
    render();
  });
}

function takeGenerationBatch(queue, activeCount, limit = TITLE_GENERATION_CONCURRENCY) {
  const available = Math.max(0, limit - activeCount);
  return queue.splice(0, available);
}

function enqueueTitle(target) {
  if (!target) return;
  if (!metaSettings.titleModel) return openGenerationSettings(target);
  if (generationChildren.has(target.id) || generationJobs.some(job => job.target.id === target.id)) return;

  generationJobs.push({
    target,
    model: metaSettings.titleModel,
    effort: metaSettings.titleThinkingLevel || 'off',
  });
  if (!generationActive) {
    generationCancelled = false;
    generationActive = true;
  }
  pumpTitleGeneration();
}

function finishGeneration() {
  generationActive = false;
  generationJobs = [];
  generationChildren.clear();
  generationCancelled = false;
  if (!handingOff) render();
}

function cancelGeneration() {
  if (!generationActive) return false;
  generationCancelled = true;
  generationJobs = [];
  for (const child of generationChildren.values()) child.kill('SIGTERM');
  if (generationChildren.size === 0) finishGeneration();
  else if (!handingOff) render();
  return true;
}

function pumpTitleGeneration() {
  if (generationCancelled) {
    if (generationChildren.size === 0) finishGeneration();
    return;
  }

  while (generationJobs.length && generationChildren.size < TITLE_GENERATION_CONCURRENCY) {
    const batch = takeGenerationBatch(generationJobs, generationChildren.size);
    for (const job of batch) startTitleGeneration(job);
  }

  if (generationJobs.length === 0 && generationChildren.size === 0) finishGeneration();
  else if (!handingOff) render();
}

function startTitleGeneration(job) {
  let prompt;
  try { prompt = buildTitlePrompt(job.target.file); }
  catch { return; }

  let stdout = '', stderr = '', settled = false;
  const child = spawn('pi', [
    '--print', '--no-session',
    '--no-extensions', '--no-skills', '--no-prompt-templates', '--no-tools',
    '--system-prompt', 'You generate durable factual topic labels, not completion reports or conversation summaries. Use base-form imperative actions in both the title and subtitle. Describe the session’s central task independent of progress, using assistant evidence only for the topic, target, and scope. Never copy status, process, accomplishments, plans, promises, tool usage, first-person wording, or report-style phrasing. Follow the user instructions exactly and output only the requested single-line title and subtitle.',
    '--model', job.model, '--thinking', job.effort, prompt,
  ], { stdio: ['ignore', 'pipe', 'pipe'] });
  generationChildren.set(job.target.id, child);
  const timer = setTimeout(() => { if (!settled) child.kill('SIGTERM'); }, 120000);
  child.stdout.on('data', d => { stdout += d; });
  child.stderr.on('data', d => { stderr += d; });
  const complete = () => {
    if (settled) return;
    settled = true;
    clearTimeout(timer);
    if (generationChildren.get(job.target.id) === child) generationChildren.delete(job.target.id);
    pumpTitleGeneration();
  };
  child.on('error', complete);
  child.on('close', code => {
    if (settled) return;
    if (code === 0) {
      try {
        saveTitle(job.target.id, cleanGeneratedTitle(stdout), 'llm', job.model, job.effort);
        return complete();
      } catch {}
    }
    complete();
  });
}

// Inline editor for a session's title or cwd. Renders a small focused panel
// so the user always sees which session + field they're changing.
function renderEdit() {
  const W = process.stdout.columns || 100;
  const s = editTarget;
  let out = A.clr;
  const label = editField === 'cwd' ? 'working directory (cwd)' : 'display title';
  out += ' ' + A.B + A.cyn + 'pisesh' + A.R + A.D + '  edit ' + label + A.R + '\n\n';
  if (!s) { out += ' (no session)\n'; process.stdout.write(out); return; }

  const row = (k, v, color = A.R) => ` ${A.D}${pad(k, 11)}${A.R} ${color}${v}${A.R}\n`;
  out += row('id', s.id, A.cyn);
  out += row('title', s.title);
  out += row('cwd', s.effectiveCwd, A.mag);
  if (editField === 'cwd') out += row('recorded', s.cwd, A.gry);
  out += '\n';

  out += ' ' + A.B + (editField === 'cwd' ? 'New cwd' : 'New title') + ':' + A.R + '\n';
  {
    // Render the caret in place: text before it, the inverse-highlighted char
    // under it (or a trailing inverse space at end), then the text after it.
    const ch = [...editBuffer];
    const before = ch.slice(0, editCursor).join('');
    const under = editCursor < ch.length ? ch[editCursor] : ' ';
    const after = ch.slice(editCursor + 1).join('');
    out += ' ' + A.cyn + '›' + A.R + ' ' + before + A.I + under + A.R + after + '\n';
  }
  if (editField === 'cwd') {
    const exists = editBuffer.trim() && fs.existsSync(editBuffer.trim());
    out += ' ' + A.D + (editBuffer.trim()
      ? (exists ? A.grn + 'path exists' : A.yel + 'path not found (saved anyway)')
      : 'empty → clears override, falls back to recorded cwd') + A.R + '\n';
  } else {
    out += ' ' + A.D + (editBuffer.trim()
      ? 'saves a custom name for this session'
      : 'empty → clears override, falls back to first prompt') + A.R + '\n';
  }

  out += '\n' + A.gry + '─'.repeat(Math.max(1, W - 1)) + A.R + '\n';
  out += ' ' + A.D + 'Enter' + A.R + ' save  '
      + A.D + '←→' + A.R + ' move  '
      + A.D + 'Ctrl-U' + A.R + ' clear  '
      + A.D + 'Esc' + A.R + ' cancel' + '\n';
  process.stdout.write(out);
}

function renderDetails() {
  const W = process.stdout.columns || 100;
  const list = visibleSessions();
  const s = list[cursor];
  let out = A.clr;
  out += ' ' + A.B + A.cyn + 'pisesh' + A.R + A.D + '  session details' + A.R + '\n\n';
  if (!s) { out += ' (no session)\n'; process.stdout.write(out); return; }

  const row = (k, v, color = A.R) => ` ${A.D}${pad(k, 11)}${A.R} ${color}${v}${A.R}\n`;
  out += row('id', s.id, A.cyn);
  if (s.isCurrent) out += row('current', '● this is the attached pi session', A.grn);
  out += row('starred', s.favored ? '★ yes' : '☆ no', s.favored ? A.yel : A.gry);
  out += row('title', s.title + (s.titleOverride ? A.cyn + `  (${s.titleSource === 'llm' ? 'generated' : 'custom'})` + A.R : ''));
  if (s.titleModel) {
    out += row('title model', s.titleModel, A.cyn);
    out += row('title effort', s.titleThinkingLevel || 'off', A.cyn);
  }
  out += row('started', new Date(s.ts).toLocaleString());
  out += row('updated', new Date(s.mtime).toLocaleString());
  out += row('cwd', s.effectiveCwd + (s.cwdOverride ? A.cyn + '  (custom)' + A.R : ''), A.mag);
  if (s.cwdOverride) out += row('recorded', s.cwd, A.gry);
  out += row('project', s.project);
  out += row('size', fmtSize(s.size));
  out += row('file', s.file, A.gry);
  out += '\n ' + A.D + 'first prompt:' + A.R + '\n';
  const prompt = s.prompt || '(no user prompt found in first 96KB)';
  const wrapped = wrap(prompt, W - 4);
  for (const line of wrapped) out += '   ' + line + '\n';

  out += '\n' + A.gry + '─'.repeat(Math.max(1, W - 1)) + A.R + '\n';
  out += ' ' + A.D + 'Enter' + A.R + ' resume  '
      + A.D + 'f' + A.R + ' star  '
      + A.D + 'e' + A.R + ' edit name  '
      + A.D + 'g' + A.R + ' generate title  '
      + A.D + 'p' + A.R + ' edit cwd  '
      + A.D + 'c' + A.R + ' copy id  '
      + A.D + 'Esc/d/q' + A.R + ' back' + A.R + '\n';

  process.stdout.write(out);
}

function wrap(text, width) {
  if (!text) return [''];
  const out = [];
  let line = '';
  for (const word of text.split(/\s+/)) {
    if ((line + ' ' + word).trim().length > width) {
      if (line) out.push(line);
      line = word;
    } else line = (line + ' ' + word).trim();
  }
  if (line) out.push(line);
  return out.slice(0, 10); // cap at 10 lines
}

// ── Input ─────────────────────────────────────────────
function setupInput() {
  readline.emitKeypressEvents(process.stdin);
  if (process.stdin.isTTY) process.stdin.setRawMode(true);
  process.stdin.resume();
  // Enter alt screen FIRST, then hide cursor. The terminal saves the user's
  // visible buffer + cursor position; we restore both on exit.
  process.stdout.write(A.enterAlt + A.hideC);

  process.stdin.on('keypress', (str, key) => {
    try {
      if (generationActive && key.ctrl && key.name === 'c') return quit();
      if (generationActive && (key.name === 'escape' || key.name === 'q')) {
        if (generationCancelled) return quit();
        cancelGeneration();
        return;
      }
      if (mode === 'filter') handleFilter(str, key);
      else if (mode === 'edit') handleEdit(str, key);
      else if (mode === 'browse') handleBrowse(str, key);
      else if (mode === 'model') handleModelPicker(str, key);
      else if (mode === 'details') handleDetails(str, key);
      else handleList(str, key);
      render();
    } catch (e) {
      process.stdout.write(A.showC);
      console.error('input error:', e);
    }
  });

  process.stdout.on('resize', render);
  // Safety net: even on unexpected exit (uncaught error, signal), leave alt
  // screen and re-show the hardware cursor so the user's terminal isn't
  // left in a broken state.
  process.on('exit', () => process.stdout.write(A.exitAlt + A.showC));
  process.on('SIGINT', () => quit());
  process.on('SIGTERM', () => quit());
}

function handleList(str, key) {
  const list = visibleSessions();
  const k = key.name;

  if (key.ctrl && k === 'c') return quit();
  if (k === 'q') {
    if (filter) { filter = ''; cursor = 0; return; }
    return quit();
  }
  // Esc: clears filter first (one-step back-out), otherwise quits.
  // Matches `q` so muscle memory works either way.
  if (k === 'escape') {
    if (filter) { filter = ''; cursor = 0; return; }
    return quit();
  }
  if (k === 'up' || k === 'k') cursor = Math.max(0, cursor - 1);
  else if (k === 'down' || k === 'j') cursor = Math.min(list.length - 1, cursor + 1);
  else if (k === 'tab' || (k === 'right' && !filter) || k === 'l') {
    tabIdx = (tabIdx + 1) % tabs.length;
    cursor = 0;
  }
  else if ((k === 'left' && !filter) || k === 'h') {
    tabIdx = (tabIdx - 1 + tabs.length) % tabs.length;
    cursor = 0;
  }
  else if (k === 'f' || str === ' ') {
    const s = list[cursor];
    if (s) {
      if (s.favored) favorites.delete(s.id);
      else favorites.add(s.id);
      saveFavorites(favorites);
    }
  }
  else if (k === 'return') resumeSession(list[cursor]);
  else if (k === 'd') { if (list[cursor]) mode = 'details'; }
  else if (k === 'e') startEdit(list[cursor], 'title');
  else if (k === 'g' && (str === 'G' || key.shift)) openGenerationSettings();
  else if (k === 'g') enqueueTitle(list[cursor]);
  else if (k === 'p') startBrowse(list[cursor]);
  else if (str === '/') { mode = 'filter'; }
  else if (k === 'r') { sessions = scanSessions(); cursor = 0; }
  else if (k === 'home') cursor = 0;
  else if (k === 'end') cursor = list.length - 1;
  else if (k === 'pageup') cursor = Math.max(0, cursor - 10);
  else if (k === 'pagedown') cursor = Math.min(list.length - 1, cursor + 10);
}

function handleFilter(str, key) {
  const k = key.name;
  if (k === 'return') { mode = 'list'; return; }
  if (k === 'escape' || k === 'q') { filter = ''; cursor = 0; mode = 'list'; return; }
  if (k === 'backspace') { filter = filter.slice(0, -1); cursor = 0; return; }
  if (key.ctrl && k === 'c') return quit();
  if (key.ctrl && k === 'u') { filter = ''; cursor = 0; return; }
  if (str && str.length === 1 && !key.ctrl) { filter += str; cursor = 0; }
}

function handleDetails(str, key) {
  const k = key.name;
  const s = visibleSessions()[cursor];
  if (k === 'escape' || k === 'q' || k === 'd') { mode = 'list'; return; }
  if (key.ctrl && k === 'c') return quit();
  if (k === 'return') return resumeSession(s);
  if (k === 'f' && s) {
    if (s.favored) favorites.delete(s.id); else favorites.add(s.id);
    saveFavorites(favorites);
  }
  if (k === 'c' && s) {
    // Try clipboard via clip.exe (WSL) or pbcopy/xclip
    tryCopy(s.id);
  }
  if (k === 'e' && s) startEdit(s, 'title');
  if (k === 'g' && (str === 'G' || key.shift)) openGenerationSettings();
  else if (k === 'g' && s) enqueueTitle(s);
  if (k === 'p' && s) startBrowse(s);
}

function handleModelPicker(str, key) {
  const k = key.name;
  const list = filteredModels();
  if (key.ctrl && k === 'c') return quit();
  if (k === 'escape' || k === 'q') {
    mode = 'list'; settingsPendingTarget = null; modelStatus = ''; return;
  }
  if (k === 'up' || k === 'k') {
    modelSel = Math.max(0, modelSel - 1);
    if (!modelThinking.has(list[modelSel])) modelEffort = 'off';
    return;
  }
  if (k === 'down' || k === 'j') {
    modelSel = Math.min(list.length - 1, modelSel + 1);
    if (!modelThinking.has(list[modelSel])) modelEffort = 'off';
    return;
  }
  if ((k === 'left' || k === 'right') && modelThinking.has(list[modelSel])) {
    const delta = k === 'right' ? 1 : -1;
    const idx = EFFORT_LEVELS.indexOf(modelEffort);
    modelEffort = EFFORT_LEVELS[(idx + delta + EFFORT_LEVELS.length) % EFFORT_LEVELS.length];
    return;
  }
  if (k === 'return') {
    if (!modelStatus.startsWith('Loading') && list[modelSel]) {
      metaSettings.titleModel = list[modelSel];
      metaSettings.titleThinkingLevel = modelEffort;
      saveMeta();
      const pending = settingsPendingTarget;
      settingsPendingTarget = null;
      mode = 'list';
      if (pending) enqueueTitle(pending);
    }
    return;
  }
  if (k === 'backspace') { modelFilter = modelFilter.slice(0, -1); modelSel = 0; return; }
  if (key.ctrl && k === 'u') { modelFilter = ''; modelSel = 0; return; }
  if (str && str.length === 1 && !key.ctrl) { modelFilter += str; modelSel = 0; }
}

// Open the inline editor for a session's title or cwd, seeded with the
// current override (or recorded cwd, so the user can tweak rather than retype).
function startEdit(s, field) {
  if (!s) return;
  editTarget = s;
  editField = field;
  editBuffer = field === 'cwd' ? (s.cwdOverride || s.cwd || '') : (s.titleOverride || '');
  editCursor = [...editBuffer].length; // start with the caret at the end
  mode = 'edit';
}

function handleEdit(str, key) {
  const k = key.name;
  if (key.ctrl && k === 'c') return quit();
  if (k === 'escape') { mode = 'list'; editTarget = null; return; }
  if (k === 'return') {
    if (editTarget) {
      if (editField === 'title') saveTitle(editTarget.id, editBuffer, 'manual');
      else setOverride(editTarget.id, editField, editBuffer);
    }
    mode = 'list';
    editTarget = null;
    return;
  }
  // Operate on code points so CJK / emoji never get split mid-character.
  const chars = [...editBuffer];
  if (editCursor > chars.length) editCursor = chars.length;
  // Move the caret inside the text the user already typed.
  if (k === 'left')  { editCursor = Math.max(0, editCursor - 1); return; }
  if (k === 'right') { editCursor = Math.min(chars.length, editCursor + 1); return; }
  if (k === 'home' || (key.ctrl && k === 'a')) { editCursor = 0; return; }
  if (k === 'end'  || (key.ctrl && k === 'e')) { editCursor = chars.length; return; }
  if (k === 'backspace') {
    if (editCursor > 0) { chars.splice(editCursor - 1, 1); editCursor--; editBuffer = chars.join(''); }
    return;
  }
  if (k === 'delete') { // forward delete (char under the caret)
    if (editCursor < chars.length) { chars.splice(editCursor, 1); editBuffer = chars.join(''); }
    return;
  }
  if (key.ctrl && k === 'u') { editBuffer = ''; editCursor = 0; return; }
  // Accept any printable char (incl. spaces, '/', CJK) but not control combos.
  if (str && !key.ctrl && str !== '\r' && str !== '\n' && str !== '\t') {
    const ins = [...str];
    chars.splice(editCursor, 0, ...ins);
    editCursor += ins.length;
    editBuffer = chars.join('');
  }
}

// ── cwd directory browser (arrow-key picker) ──────────────────
// List immediate subdirectories of `dir` (symlinks-to-dirs included),
// alphabetically, swallowing permission errors so the picker never crashes.
function listDirs(dir) {
  try {
    return fs.readdirSync(dir, { withFileTypes: true })
      .filter(d => {
        try {
          if (d.isDirectory()) return true;
          if (d.isSymbolicLink()) return fs.statSync(path.join(dir, d.name)).isDirectory();
        } catch { /* unreadable entry */ }
        return false;
      })
      .map(d => d.name)
      .sort((a, b) => a.localeCompare(b));
  } catch { return []; }
}

// Rebuild the browser's entry list for `dir`. Falls back to the nearest
// existing ancestor (or '/') if the path is gone, so resume targets that no
// longer exist still open somewhere sensible.
function buildBrowse(dir) {
  let d = dir || '/';
  // Walk up until we hit something that exists and is a directory.
  while (d && d !== '/' && (!fs.existsSync(d) || !safeIsDir(d))) d = path.dirname(d);
  if (!fs.existsSync(d)) d = '/';
  browseDir = path.resolve(d);
  const entries = [{ label: '[· use THIS directory]', kind: 'use', path: browseDir }];
  if (browseDir !== '/') entries.push({ label: '..  (parent)', kind: 'up', path: path.dirname(browseDir) });
  for (const name of listDirs(browseDir)) entries.push({ label: name + '/', kind: 'dir', path: path.join(browseDir, name) });
  browseEntries = entries;
  browseSel = 0;
}

function safeIsDir(p) { try { return fs.statSync(p).isDirectory(); } catch { return false; } }

// Enter the cwd picker for a session, seeded at its current effective cwd.
function startBrowse(s) {
  if (!s) return;
  editTarget = s;
  editField = 'cwd';
  buildBrowse(s.cwdOverride || s.cwd || CURRENT_CWD || '/');
  mode = 'browse';
}

// Persist the currently-browsed directory as this session's cwd override.
function commitBrowse() {
  if (editTarget) setOverride(editTarget.id, 'cwd', browseDir);
  mode = 'list';
  editTarget = null;
}

function handleBrowse(str, key) {
  const k = key.name;
  if (key.ctrl && k === 'c') return quit();
  if (k === 'escape') { mode = 'list'; editTarget = null; return; }
  if (k === 'up' || k === 'k') browseSel = Math.max(0, browseSel - 1);
  else if (k === 'down' || k === 'j') browseSel = Math.min(browseEntries.length - 1, browseSel + 1);
  else if (k === 'pageup') browseSel = Math.max(0, browseSel - 10);
  else if (k === 'pagedown') browseSel = Math.min(browseEntries.length - 1, browseSel + 10);
  else if (k === 'home') browseSel = 0;
  else if (k === 'end') browseSel = browseEntries.length - 1;
  // Left / h: go to parent directory.
  else if (k === 'left' || k === 'h') { if (browseDir !== '/') buildBrowse(path.dirname(browseDir)); }
  // Right / l / Enter: open the highlighted dir (or commit if it's the
  // "use THIS directory" / parent row).
  else if (k === 'right' || k === 'l' || k === 'return') {
    const e = browseEntries[browseSel];
    if (!e) return;
    if (e.kind === 'use') return commitBrowse();
    buildBrowse(e.path);
  }
  // s: select the directory we're currently inside, from anywhere.
  else if (k === 's') commitBrowse();
}

// Focused full-screen directory picker. ANSI-padded selected row matches the
// main list look so it feels like the same widget.
function renderBrowse() {
  const W = process.stdout.columns || 100;
  const H = process.stdout.rows || 30;
  const s = editTarget;
  let out = A.clr;
  out += ' ' + A.B + A.cyn + 'pisesh' + A.R + A.D + '  edit cwd — pick working directory' + A.R + '\n\n';
  if (!s) { out += ' (no session)\n'; process.stdout.write(out); return; }

  const row = (key, v, color = A.R) => ` ${A.D}${pad(key, 9)}${A.R} ${color}${v}${A.R}\n`;
  out += row('session', trunc(s.title, W - 14));
  out += row('current', s.effectiveCwd, A.mag);
  out += '\n ' + A.B + 'In:' + A.R + ' ' + A.cyn + trunc(browseDir, W - 6) + A.R + '\n';
  out += A.gry + '─'.repeat(Math.max(1, W - 1)) + A.R + '\n';

  const headerH = 7;
  const footerH = 3;
  const usable = Math.max(3, H - headerH - footerH);
  if (browseSel >= browseEntries.length) browseSel = Math.max(0, browseEntries.length - 1);
  const start = Math.max(0, Math.min(browseSel - Math.floor(usable / 2), browseEntries.length - usable));
  const end = Math.min(browseEntries.length, start + usable);
  for (let i = start; i < end; i++) {
    const e = browseEntries[i];
    const sel = i === browseSel;
    const arrow = sel ? A.cyn + '▶' + A.R : ' ';
    const color = e.kind === 'use' ? A.grn + A.B : (e.kind === 'up' ? A.yel : A.R);
    const rowText = ` ${arrow} ${color}${trunc(e.label, W - 6)}${A.R}`;
    if (sel) {
      const pad2 = ' '.repeat(Math.max(0, W - visLen(rowText) - 1));
      out += A.bgBlu + rowText + pad2 + A.R + '\n';
    } else out += rowText + '\n';
  }
  const linesUsed = (end - start) || 1;
  for (let i = 0; i < usable - linesUsed; i++) out += '\n';

  out += A.gry + '─'.repeat(Math.max(1, W - 1)) + A.R + '\n';
  out += ' ' + A.D + '↑↓' + A.R + ' move  '
      + A.D + '→/Enter' + A.R + ' open dir  '
      + A.D + '←' + A.R + ' parent  '
      + A.grn + A.B + 's' + A.R + A.D + ' SELECT this dir  '
      + A.D + 'Esc' + A.R + ' cancel' + A.R + '\n';
  process.stdout.write(out);
}

function tryCopy(text) {
  const tryCmd = (cmd, args) => {
    try {
      const p = spawn(cmd, args, { stdio: ['pipe', 'ignore', 'ignore'] });
      p.stdin.end(text);
      return true;
    } catch { return false; }
  };
  // WSL clip.exe first, then pbcopy, then xclip
  tryCmd('clip.exe', []) || tryCmd('pbcopy', []) || tryCmd('xclip', ['-selection', 'clipboard']);
}

// ── Actions ───────────────────────────────────────────
// Heal a session before resuming. On resume, pi re-executes (or chokes on) any
// toolCall that has no recorded toolResult — e.g. an image generation that was
// interrupted when the prior session hit a usage limit or was closed mid-tool.
// Left unhealed, the spawned pi crashes (exit 1), which surfaces to the parent
// as "pisesh exited with code N". We inject a synthetic "[interrupted]"
// toolResult for unfinished valid turns, but not errored/aborted assistant turns
// that pi omits during replay. Old incompatible synthetic results are removed.
// Idempotent; never throws.
function healOrphanedToolCalls(file) {
  try {
    const lines = fs.readFileSync(file, 'utf8').split('\n').filter(Boolean);
    const entries = lines.map(raw => {
      try { return { raw, value: JSON.parse(raw) }; } catch { return { raw, value: null }; }
    });
    const droppedToolCallIds = new Set();
    for (const { value: o } of entries) {
      const m = o && o.message;
      if (m && m.role === 'assistant' && (m.stopReason === 'error' || m.stopReason === 'aborted')) {
        for (const b of Array.isArray(m.content) ? m.content : []) {
          if (b && b.type === 'toolCall' && b.id) droppedToolCallIds.add(b.id);
        }
      }
    }

    const removedParents = new Map();
    const kept = entries.filter(({ value: o }) => {
      const m = o && o.message;
      const text = m && Array.isArray(m.content) && m.content.find(b => b && b.type === 'text');
      const isBadSynthetic = m && m.role === 'toolResult'
        && droppedToolCallIds.has(m.toolCallId)
        && text && text.text.startsWith('[tool call interrupted');
      if (isBadSynthetic) removedParents.set(o.id, o.parentId);
      return !isBadSynthetic;
    });
    for (const { value: o } of kept) {
      if (!o || typeof o.parentId === 'undefined') continue;
      while (removedParents.has(o.parentId)) o.parentId = removedParents.get(o.parentId);
    }

    const resultIds = new Set();
    for (const { value: o } of kept) {
      if (o && o.message && o.message.role === 'toolResult') resultIds.add(o.message.toolCallId);
    }
    const rnd = () => Math.random().toString(16).slice(2, 10);
    const out = [];
    let inserted = 0, prevSynthId = null;
    for (const { raw, value: o } of kept) {
      if (!o) { out.push(raw); continue; }
      if (prevSynthId && typeof o.parentId !== 'undefined') { o.parentId = prevSynthId; prevSynthId = null; }
      out.push(JSON.stringify(o));
      const m = o.message;
      const c = m && m.content;
      if (m && m.role === 'assistant' && m.stopReason !== 'error' && m.stopReason !== 'aborted' && Array.isArray(c)) {
        for (const b of c) {
          if (b && b.type === 'toolCall' && b.id && !resultIds.has(b.id)) {
            const synth = {
              type: 'message', id: rnd(), parentId: o.id,
              timestamp: new Date().toISOString(),
              message: {
                role: 'toolResult', toolCallId: b.id, toolName: b.name,
                content: [{ type: 'text', text: '[tool call interrupted \u2014 the previous session ended before this tool finished (e.g. usage limit reached or session closed); no result was recorded]' }],
                isError: true, timestamp: Date.now(),
              },
            };
            out.push(JSON.stringify(synth));
            resultIds.add(b.id);
            prevSynthId = synth.id;
            inserted++;
          }
        }
      }
    }
    const changed = removedParents.size + inserted;
    if (changed > 0) {
      try { const bak = file + '.bak-orphanheal'; if (!fs.existsSync(bak)) fs.copyFileSync(file, bak); } catch {}
      fs.writeFileSync(file, out.join('\n') + '\n');
    }
    return changed;
  } catch { return 0; }
}

function resumeSession(s) {
  if (!s) return;
  // A resumed pi takes over this terminal, so stop background title work first
  // and suppress any final render from its asynchronous close handler.
  handingOff = true;
  cancelGeneration();
  // Heal orphaned tool calls before handing off, so resume can't crash the
  // spawned pi (see healOrphanedToolCalls).
  try { healOrphanedToolCalls(s.file); } catch {}
  // Leave alt screen + show cursor so the spawned pi takes over a clean
  // main-buffer terminal (it will manage its own alt screen).
  process.stdout.write(A.exitAlt + A.showC);
  if (process.stdin.isTTY) process.stdin.setRawMode(false);
  process.stdin.pause();

  const projectDir = path.dirname(s.file);
  // Resume in the session's effective cwd (user override wins over recorded),
  // falling back to pisesh's own cwd if that directory no longer exists.
  const targetCwd = s.effectiveCwd;
  const child = spawn('pi', ['--session', s.id, '--session-dir', projectDir], {
    stdio: 'inherit',
    cwd: targetCwd && fs.existsSync(targetCwd) ? targetCwd : process.cwd(),
  });
  child.on('exit', code => process.exit(code || 0));
  child.on('error', err => {
    console.error('Failed to spawn pi:', err.message);
    process.exit(1);
  });
}

function quit() {
  handingOff = true;
  for (const child of generationChildren.values()) child.kill('SIGTERM');
  // Restore user's pre-pisesh terminal (alt screen exits + cursor back).
  // No explicit clear needed — the terminal restoration handles it and the
  // jump back to the previous prompt feels instant.
  process.stdout.write(A.exitAlt + A.showC);
  if (process.stdin.isTTY) process.stdin.setRawMode(false);
  process.exit(0);
}

// ── Main ──────────────────────────────────────────────
function printHelp() {
  console.log(`pisesh — pi session bookmarks & resume TUI

Usage:
  pisesh                 Open interactive TUI
  pisesh --list, -l      List starred session IDs (one per line)
  pisesh --json          Dump favorites file as JSON
  pisesh --star <id>     Add a session id (partial UUID ok) to favorites
  pisesh --unstar <id>   Remove a session id from favorites
  pisesh --help, -h      This help

TUI keys:
  ↑↓ / j k         move cursor
  Tab / h l        switch tab  (★ Favorites → Today → Here → All)
  f / Space        toggle favorite
  Enter            resume session (spawns 'pi --session …' in its cwd)
  e                edit name (custom display title)
  g                queue title generation with the saved model + effort
                   (first use opens settings; active/queued threads are ignored)
  G                open title generation model + effort settings
  p                edit cwd — arrow-key directory browser
                   (↑↓ move, →/Enter open dir, ← parent, s select, Esc cancel)
                   sets the working directory used on resume / "Here" tab
  d                show details
  /                search (id / project / prompt / title)
  r                rescan session files
  q / Esc          cancel generation / clear search first; press again to quit
  Ctrl-C           cancel generation and quit immediately

Tabs:
  Here             only sessions whose cwd matches the directory pisesh was
                   launched from (\$PISESH_CWD, else process cwd)

Files:
  Favorites: ${FAV_FILE}
  Overrides: ${META_FILE}
  Sessions : ${SESSIONS_ROOT}/<project>/<ts>_<uuid>.jsonl`);
}

function findIdMatch(prefix) {
  sessions = scanSessions();
  const matches = sessions.filter(s => s.id.startsWith(prefix) || s.id.includes(prefix));
  return matches.map(s => s.id);
}

function main() {
  const argv = process.argv.slice(2);

  if (argv.includes('-h') || argv.includes('--help')) { printHelp(); return; }
  if (argv.includes('-l') || argv.includes('--list')) {
    [...favorites].forEach(id => console.log(id));
    return;
  }
  if (argv.includes('--json')) {
    console.log(JSON.stringify({ ids: [...favorites], updated: new Date().toISOString() }, null, 2));
    return;
  }

  const starIdx = argv.indexOf('--star');
  if (starIdx >= 0 && argv[starIdx + 1]) {
    const ids = findIdMatch(argv[starIdx + 1]);
    if (ids.length === 0) { console.error('no matching session'); process.exit(2); }
    if (ids.length > 1) { console.error('ambiguous:'); ids.forEach(i => console.error(' ', i)); process.exit(2); }
    favorites.add(ids[0]); saveFavorites(favorites);
    console.log('★ starred', ids[0]); return;
  }
  const unstarIdx = argv.indexOf('--unstar');
  if (unstarIdx >= 0 && argv[unstarIdx + 1]) {
    const ids = findIdMatch(argv[unstarIdx + 1]);
    if (ids.length === 0) { console.error('no matching session'); process.exit(2); }
    if (ids.length > 1) { console.error('ambiguous:'); ids.forEach(i => console.error(' ', i)); process.exit(2); }
    favorites.delete(ids[0]); saveFavorites(favorites);
    console.log('☆ unstarred', ids[0]); return;
  }

  if (!process.stdin.isTTY) {
    console.error('pisesh: stdin is not a TTY (use a terminal to run the TUI). Try --list or --help.');
    process.exit(1);
  }

  sessions = scanSessions();
  if (sessions.length === 0) {
    console.error('pisesh: no sessions found under', SESSIONS_ROOT);
    process.exit(1);
  }
  setupInput();
  render();
}

if (require.main === module) main();
else module.exports = { healOrphanedToolCalls, parseModelEntries, parseModelList, buildTitlePrompt, cleanGeneratedTitle, takeGenerationBatch };
